# ── EAS Build ignore ──────────────────────────────────────────────────────────
# EAS reinstalls node_modules fresh on the build server via lockfile.
node_modules/

# Expo local metro / build cache — not needed on the server
.expo/
dist/
web-build/
.metro-health-check*

# Generated native directories — EAS generates these during managed build
android/
ios/

# Git history — not needed, saves upload time
.git/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS junk
.DS_Store
Thumbs.db

# IDE config
.vscode/
.idea/

# Test output / coverage
coverage/
__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# Play Store service account key — never upload secrets
play-store-key.json

# Docs / planning files — not needed for build
docs/
*.md
!README.md

# Original pre-compression image backups — huge, never upload
assets/creatures/_originals/

# Dr. Icky videos — streamed from Firebase Storage, never bundle in APK
assets/dr-icky/

# Compression script — not needed for build
scripts/
